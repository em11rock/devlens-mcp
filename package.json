{
  "name": "devlens-mcp",
  "version": "0.1.0",
  "description": "Real-time visual feedback plugin for Claude Code frontend development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devlens-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "README.md"
  ],
  "keywords": [
    "claude",
    "mcp",
    "claude-code",
    "playwright",
    "visual-testing",
    "frontend"
  ],
  "license": "MIT",
  "scripts": {
