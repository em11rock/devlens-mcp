    "minimatch": "^10.2.5",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.45.0",
    "pngjs": "^7.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
